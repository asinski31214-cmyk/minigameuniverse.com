<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minigame Universe</title>
    <style>
        :root {
            --bg-blue: #e0f2fe;
            --accent: #0ea5e9;
            --text: #0369a1;
            --success: #4ade80;
        }

        body, html {
            margin: 0; padding: 0;
            font-family: 'Segoe UI', system-ui, sans-serif;
            background-color: var(--bg-blue);
            color: var(--text);
            height: 100vh; overflow: hidden;
        }

        /* --- UI NAVIGATION --- */
      #menu {
    width: 100%; height: 100%;
    display: flex; flex-direction: column; align-items: center;
    overflow-y: auto; 
    padding-bottom: 50px;
}
#game-container { 
    width: 100%; height: 100%; 
    display: none; flex-direction: column; align-items: center; 
}

        #game-container { display: none; background: #0f172a; color: white; position: relative; }
       
        /* --- MENU STYLE --- */
        h1 { 
    margin: 0; 
    padding: 40px 0 20px 0; 
    font-size: 3rem; 
    text-transform: uppercase; 
    position: sticky; 
    top: 0; 
    background: var(--bg-blue); 
    width: 100%; 
    text-align: center; 
    z-index: 10; 
}
       
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px; width: 85%; max-width: 1000px; margin-top: 30px;
    flex-shrink: 0; 
}

        .card {
            background: white; border-radius: 20px; padding: 30px;
            text-align: center; cursor: pointer; transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05); border: 3px solid transparent;
        }

        .card:hover { transform: translateY(-10px); border-color: var(--accent); box-shadow: 0 15px 30px rgba(14, 165, 233, 0.2); }
        .card span { font-size: 55px; display: block; margin-bottom: 10px; }

        #back-btn {
            position: absolute; top: 20px; left: 20px; z-index: 100;
            padding: 12px 24px; background: #ef4444; color: white;
            border: none; border-radius: 12px; cursor: pointer; font-weight: bold;
            transition: 0.2s;
        }
        #back-btn:hover { background: #b91c1c; transform: scale(1.05); }

        /* --- TYCOON SPECIFIC --- */
        .worker {
            position: absolute; font-size: 25px; transition: all 2s linear;
            user-select: none; display: flex; flex-direction: column; align-items: center; z-index: 5;
        }
        .worker-label { font-size: 9px; background: rgba(0,0,0,0.7); color: white; padding: 1px 4px; border-radius: 4px; margin-top: -5px; }
       
        #office-floor {
            width: 90%; height: 250px; background: #1e293b; border-radius: 15px;
            margin: 15px 0; position: relative; overflow: hidden;
            border: 3px solid var(--success); transition: 0.5s;
        }

        .floating-text {
            position: absolute; color: var(--success); font-weight: bold;
            pointer-events: none; animation: floatUp 0.8s ease-out forwards; z-index: 50;
        }

        @keyframes floatUp {
            0% { opacity: 1; transform: translateY(0); }
            100% { opacity: 0; transform: translateY(-50px); }
        }

        .game-ui { display: flex; flex-direction: column; align-items: center; width: 100%; height: 100%; justify-content: center; }
        .upgrade-btn {
            padding: 12px; margin: 4px; cursor: pointer; background: #334155;
            color: white; border: 1px solid #475569; border-radius: 10px; width: 260px;
            font-weight: bold; transition: 0.2s;
        }
        .upgrade-btn:hover:not([style*="opacity: 0.5"]) { background: #475569; transform: scale(1.02); }

        canvas { border-radius: 15px; box-shadow: 0 0 30px rgba(0,0,0,0.5); }
    </style>
</head>
<body>

    <div id="menu">
        <h1>Minigame Universe</h1>
        <div class="grid">
            <div class="card" onclick="launch('stars')"><span>⭐</span><strong>Star Collector</strong></div>
            <div class="card" onclick="launch('clicker')"><span>⚡</span><strong>Neon Clicker</strong></div>
            <div class="card" onclick="launch('type')"><span>⌨️</span><strong>Speed Typer</strong></div>
            <div class="card" onclick="launch('tycoon')"><span>🏢</span><strong>Office Tycoon</strong></div>
            <div class="card" onclick="launch('soccer')"><span>⚽</span><strong>Penalty King</strong></div>
            <div class="card" onclick="launch('art')"><span>🎨</span><strong>Art Creator</strong></div>
            <div class="card" onclick="launch('skee')"><span>🎟️</span><strong>Skee-Ball</strong></div>
            <div class="card" onclick="launch('diver')"><span>🤿</span><strong>Deep Sea Diver</strong></div>
            <div class="card" onclick="launch('spam')"><span>⌨️</span><strong>SPAM</strong></div>
            <div class="card" onclick="launch('shield')"><span>🛡️</span><strong>Shield Defender</strong></div>
            <div class="card" onclick="launch('lander')"><span>🚀</span><strong>Planet Lander</strong></div>
            <div class="card" onclick="launch('farm')"><span>🚜</span><strong>Farming Frenzy</strong></div>
            <div class="card" onclick="launch('snake')"><span>🐍</span><strong>Retro Snake</strong></div>
        </div>
        <button onclick="clearSave()" style="margin-top: 40px; opacity: 0.5; border: none; background: none; cursor: pointer; color: #64748b;">Reset All Data</button>
    </div>

    <div id="game-container">
        <button id="back-btn" onclick="exitToMenu()">🏠 MENU</button>
        <div id="stage" style="width:100%; height:100%;"></div>
    </div>

    <script>
        const menu = document.getElementById('menu');
        const container = document.getElementById('game-container');
        const stage = document.getElementById('stage');
        let activeInterval = null;

        // --- GLOBAL SAVE SYSTEM ---
      let gameData = JSON.parse(localStorage.getItem('minigameSave')) || {
    clicker: { score: 0, power: 1, auto: 0, costM: 10, costA: 50 },
    tycoon: { money: 0, helpers: 0, managers: 0, hCost: 15, mCost: 100, floorLevel: 1 },
    farm: { coins: 50, seedLevel: 1, plots: Array(9).fill().map(() => ({state:'empty', time:0})) }
};

        function saveData() {
            localStorage.setItem('minigameSave', JSON.stringify(gameData));
        }

        function clearSave() {
            if(confirm("Are you sure? This deletes everything!")) {
                localStorage.removeItem('minigameSave');
                location.reload();
            }
        }

        function exitToMenu() {
            if(activeInterval) clearInterval(activeInterval);
            container.style.display = 'none';
            menu.style.display = 'flex';
            stage.innerHTML = '';
            saveData();
        }


// Update the master launch function
function launch(game) {
    if(activeInterval) {
        cancelAnimationFrame(activeInterval);
        clearInterval(activeInterval);
    }
    menu.style.display = 'none';
    container.style.display = 'flex';
    stage.innerHTML = '';

    if(game === 'stars') startStars();
    if(game === 'clicker') startClicker();
    if(game === 'type') startType();
    if(game === 'tycoon') startTycoon();
    if(game === 'kart') startKart(); // Added
    if(game === 'soccer') startSoccer();
    if(game === 'farm') startFarm();
    if(game === 'art') startArt();
    if(game === 'skee') startSkee();
    if(game === 'diver') startDiver();
    if(game === 'spam') startSpam();
    if(game === 'shield') startShield();
    if(game === 'lander') startLander();
    if(game === 'snake') startSnake();
}

        // --- GAME 1: STAR COLLECTOR ---
        function startStars() {
            stage.innerHTML = `<div class="game-ui"><h3>Score: <span id="sc">0</span></h3><canvas id="c" width="800" height="500"></canvas></div>`;
            const canvas = document.getElementById('c'), ctx = canvas.getContext('2d');
            let score = 0, star = {x: 400, y: 250}, player = {x: 0, y: 0};
            canvas.onmousemove = (e) => {
                const r = canvas.getBoundingClientRect();
                player.x = e.clientX - r.left; player.y = e.clientY - r.top;
            };
            function draw() {
                if(container.style.display === 'none') return;
                ctx.fillStyle = "#0f172a"; ctx.fillRect(0,0,800,500);
                ctx.fillStyle = "#fbbf24"; ctx.beginPath(); ctx.arc(star.x, star.y, 10, 0, 7); ctx.fill();
                ctx.strokeStyle = "#22d3ee"; ctx.lineWidth = 3; ctx.strokeRect(player.x-15, player.y-15, 30, 30);
                if(Math.hypot(player.x-star.x, player.y-star.y) < 25) {
                    score++; document.getElementById('sc').innerText = score;
                    star = {x: Math.random()*760+20, y: Math.random()*460+20};
                }
                requestAnimationFrame(draw);
            }
            draw();
        }

        // --- GAME 2: NEON CLICKER ---
        function startClicker() {
            let d = gameData.clicker;
            stage.innerHTML = `
                <div class="game-ui">
                    <h1 id="cs" style="font-size: 5rem; margin: 10px;">0</h1>
                    <p>Power: x<span id="cp">1</span> | Auto: <span id="ca">0</span>/s</p>
                    <button class="btn-tap" id="tapper" style="border-color: #22d3ee; color: #22d3ee;">TAP</button>
                    <div style="margin-top:25px; display:flex; flex-direction:column;">
                        <button class="upgrade-btn" id="buym"></button>
                        <button class="upgrade-btn" id="buya"></button>
                        <button class="upgrade-btn" id="up-shield" onclick="buyShieldLink()">
    Sync Shield Core (Cost: 500)
</button>
                    </div>
                </div>`;
           
            const refresh = () => {
                document.getElementById('cs').innerText = Math.floor(d.score);
                document.getElementById('cp').innerText = d.power;
                document.getElementById('ca').innerText = d.auto;
                document.getElementById('buym').innerText = `Upgrade Multi (Cost: ${d.costM})`;
                document.getElementById('buya').innerText = `Buy Auto-Click (Cost: ${d.costA})`;
                saveData();
            };

            document.getElementById('tapper').onclick = (e) => {
                d.score += d.power;
                createFloatingText(e.clientX, e.clientY, `+${d.power}`);
                refresh();
            };
            document.getElementById('buym').onclick = () => {
                if(d.score >= d.costM) { d.score -= d.costM; d.power++; d.costM = Math.floor(d.costM*1.6); refresh(); }
            };
            document.getElementById('buya').onclick = () => {
                if(d.score >= d.costA) { d.score -= d.costA; d.auto++; d.costA = Math.floor(d.costA*2); refresh(); }
            };
            window.buyShieldLink = () => {
    let d = gameData.clicker;
    if (d.score >= 500 && !gameData.shieldLinked) {
        d.score -= 500;
        gameData.shieldLinked = true; // This is the "Flag"
        saveData();
        refresh();
        alert("CORE SYNCED: Double Shields Activated in Defender!");
    } else if (gameData.shieldLinked) {
        alert("Already Synced!");
    }
};

            activeInterval = setInterval(() => { if(d.auto > 0) { d.score += (d.auto/10); refresh(); } }, 100);
            refresh();
        }

// --- UPDATED GAME 3: SPEED TYPER (WITH WPM POP-UP) ---
function startType() {
    const words = ["GALAXY", "CODING", "NEON", "PIXEL", "SPACE", "LOGIC", "WEBSITE", "CYBER", "VELOCITY", "ENGINE", "MINIGAMES", "FUN", "GAMES"];
    let score = 0;
    let startTime = Date.now();

    // Style for the WPM announcement
    const style = document.createElement('style');
    style.innerHTML = `
        @keyframes wpmPop {
            0% { transform: scale(0); opacity: 0; }
            50% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(1); opacity: 0; }
        }
        .wpm-badge {
            position: absolute;
            top: 30%;
            font-size: 3rem;
            font-weight: 800;
            color: #fbbf24;
            text-shadow: 0 0 20px rgba(251, 191, 36, 0.6);
            pointer-events: none;
            animation: wpmPop 1.5s ease-out forwards;
            z-index: 100;
        }
    `;
    document.head.appendChild(style);

    stage.innerHTML = `
        <div class="game-ui">
            <div id="wpm-container"></div>
            <h2 style="color: #94a3b8;">Type the word:</h2>
            <h1 id="tw" style="font-size:4.5rem; color:#22d3ee; margin-bottom: 20px; letter-spacing: 5px;">GALAXY</h1>
            <input type="text" id="ti" autofocus autocomplete="off"
                style="padding:20px; font-size:2rem; border-radius:15px; border:3px solid #334155;
                text-align:center; background: #1e293b; color: white; width: 350px; outline: none; transition: 0.2s;">
            <h3 style="margin-top: 20px; color: #64748b;">Total Words: <span id="ts" style="color: white;">0</span></h3>
        </div>`;

    const input = document.getElementById('ti');
    const target = document.getElementById('tw');
    const wpmContainer = document.getElementById('wpm-container');

    input.oninput = () => {
        // Change border color as you type
        input.style.borderColor = target.innerText.startsWith(input.value.toUpperCase()) ? "#22d3ee" : "#ef4444";

        if (input.value.toUpperCase() === target.innerText) {
            // 1. Calculate WPM
            const timeTaken = (Date.now() - startTime) / 1000; // in seconds
            const wordLen = target.innerText.length;
            const wpm = Math.round((wordLen / 5) / (timeTaken / 60));

            // 2. Show WPM Pop-up
            const badge = document.createElement('div');
            badge.className = 'wpm-badge';
            badge.innerText = `${wpm} WPM`;
            wpmContainer.appendChild(badge);
            setTimeout(() => badge.remove(), 1500);

            // 3. Update Score and Reset
            score++;
            document.getElementById('ts').innerText = score;
            input.value = "";
            input.style.borderColor = "#334155";
            target.innerText = words[Math.floor(Math.random() * words.length)];
           
            // 4. Reset timer for the next word
            startTime = Date.now();
        }
    };
}

        // --- GAME 4: OFFICE TYCOON ---
        function startTycoon() {
            let t = gameData.tycoon;
            stage.innerHTML = `
                <div class="game-ui">
                    <h1 style="color: #4ade80; font-size: 3.5rem; margin: 10px;">$ <span id="money">0</span></h1>
                    <p>Income: $<span id="ips">0</span>/sec</p>
                    <div id="office-floor"><div id="worker-area"></div></div>
                    <button class="btn-tap" id="work-btn" style="border-color: #4ade80; color: #4ade80; height: 70px; width: 160px; border-radius: 15px; font-size: 1.2rem;">WORK</button>
                    <div style="margin-top: 15px; display: flex; flex-wrap: wrap; justify-content: center; gap: 5px;">
                        <button class="upgrade-btn" id="buy-h"></button>
                        <button class="upgrade-btn" id="buy-m"></button>
                        <button class="upgrade-btn" id="buy-f" style="background: #1e293b; border-color: #fbbf24;">Expand Office ($500)</button>
                    </div>
                </div>`;

            const workerArea = document.getElementById('worker-area');
            const floor = document.getElementById('office-floor');

            const addWorker = (emoji, type) => {
                const c = document.createElement('div');
                c.className = 'worker';
                c.style.left = Math.random()*85 + "%"; c.style.top = Math.random()*75 + "%";
                c.innerHTML = `<span>${emoji}</span><span class="worker-label">${type}</span>`;
                workerArea.appendChild(c);
                const move = () => {
                    if(!document.body.contains(c)) return;
                    let nX = Math.random()*85, nY = Math.random()*75;
                    c.style.transform = nX < parseFloat(c.style.left) ? "scaleX(-1)" : "scaleX(1)";
                    c.style.left = nX + "%"; c.style.top = nY + "%";
                    setTimeout(move, 2000 + Math.random()*3000);
                };
                setTimeout(move, 100);
            };

            // Restore visual workers
            for(let i=0; i<t.helpers; i++) addWorker('👨‍💻', 'INT');
            for(let i=0; i<t.managers; i++) addWorker('🧑‍💼', 'MGR');
            floor.style.height = (250 + (t.floorLevel-1)*50) + "px";

            const update = () => {
                document.getElementById('money').innerText = Math.floor(t.money);
                document.getElementById('ips').innerText = (t.helpers * 1 + t.managers * 8).toFixed(1);
                document.getElementById('buy-h').innerText = `Hire Intern ($${t.hCost})`;
                document.getElementById('buy-m').innerText = `Hire Manager ($${t.mCost})`;
                document.getElementById('buy-f').innerText = `Expand Office ($${t.floorLevel * 500})`;
               
                document.getElementById('buy-h').style.opacity = t.money >= t.hCost ? 1 : 0.5;
                document.getElementById('buy-m').style.opacity = t.money >= t.mCost ? 1 : 0.5;
                document.getElementById('buy-f').style.opacity = t.money >= (t.floorLevel * 500) ? 1 : 0.5;
                saveData();
            };

            document.getElementById('work-btn').onclick = (e) => {
                t.money += 1; createFloatingText(e.clientX, e.clientY, "+$1"); update();
            };
            document.getElementById('buy-h').onclick = () => {
                if(t.money >= t.hCost) { t.money -= t.hCost; t.helpers++; t.hCost = Math.floor(t.hCost*1.2); addWorker('👨‍💻', 'INT'); update(); }
            };
            document.getElementById('buy-m').onclick = () => {
                if(t.money >= t.mCost) { t.money -= t.mCost; t.managers++; t.mCost = Math.floor(t.mCost*1.3); addWorker('🧑‍💼', 'MGR'); update(); }
            };
            document.getElementById('buy-f').onclick = () => {
                let cost = t.floorLevel * 500;
                if(t.money >= cost) { t.money -= cost; t.floorLevel++; floor.style.height = (250 + (t.floorLevel-1)*50) + "px"; update(); }
            };

            activeInterval = setInterval(() => { t.money += (t.helpers*1 + t.managers*8)/10; update(); }, 100);
            update();
        }

        function createFloatingText(x, y, text) {
            const el = document.createElement('div');
            el.className = 'floating-text';
            el.innerText = text;
            el.style.left = x + "px"; el.style.top = y + "px";
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 800);
        }
// --- GAME 6: SOCCER SHOOT-OUT ---
function startSoccer() {
    let score = 0;
    let blocks = 0;
    let arrowAngle = 0;
    let arrowDir = 1;
    let goalieX = 400;
    let goalieDir = 1;
    let isKicking = false;
    let ballPos = { x: 400, y: 500 };
    let ballTarget = { x: 400, y: 500 };

    stage.innerHTML = `
        <div class="game-ui" style="background: linear-gradient(#0ea5e9, #22c55e); position:relative;">
            <div style="position:absolute; top:20px; right:20px; text-align:right; font-weight:bold; font-size:1.5rem; text-shadow: 2px 2px black;">
                SCORE: <span id="soc-score">0</span><br>
                BLOCKS: <span id="soc-blocks">0</span>/3
            </div>
            <canvas id="soc-canvas" width="800" height="600"></canvas>
            <h2 id="soc-msg" style="position:absolute; top:40%; width:100%; text-align:center; font-size:3rem; display:none;">GOAL!</h2>
        </div>
    `;

    const canvas = document.getElementById('soc-canvas');
    const ctx = canvas.getContext('2d');
    const msg = document.getElementById('soc-msg');

    function draw() {
        if (container.style.display === 'none') return;
        ctx.clearRect(0, 0, 800, 600);

        // Draw Goal
        ctx.strokeStyle = "white"; ctx.lineWidth = 10;
        ctx.strokeRect(200, 50, 400, 200);

        // Move & Draw Goalie
        if (!isKicking) {
            goalieX += 4 * goalieDir;
            if (goalieX > 550 || goalieX < 250) goalieDir *= -1;
        }
        ctx.fillStyle = "#ef4444"; // Red Goalie
        ctx.fillRect(goalieX - 30, 150, 60, 80);
        ctx.fillStyle = "white"; ctx.fillText("GK", goalieX - 10, 200);

        // Arrow Logic
        if (!isKicking) {
            arrowAngle += 0.05 * arrowDir;
            if (arrowAngle > 1 || arrowAngle < -1) arrowDir *= -1;
           
            ctx.save();
            ctx.translate(400, 500);
            ctx.rotate(arrowAngle);
            ctx.strokeStyle = "#fbbf24"; ctx.lineWidth = 5;
            ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(0, -100); ctx.stroke();
            ctx.restore();
        }

        // Ball Logic
        if (isKicking) {
            ballPos.x += (ballTarget.x - ballPos.x) * 0.1;
            ballPos.y += (ballTarget.y - ballPos.y) * 0.1;

            if (Math.abs(ballPos.y - ballTarget.y) < 5) {
                checkResult();
            }
        }

        // Draw Ball
        ctx.fillStyle = "white";
        ctx.beginPath(); ctx.arc(ballPos.x, ballPos.y, 15, 0, Math.PI*2); ctx.fill();
        ctx.strokeStyle = "black"; ctx.lineWidth = 2; ctx.stroke();

        activeInterval = requestAnimationFrame(draw);
    }

    function shoot() {
        if (isKicking || blocks >= 3) return;
        isKicking = true;
        // Calculate where the ball goes based on arrow angle
        ballTarget = {
            x: 400 + Math.sin(arrowAngle) * 400,
            y: 150
        };
    }

    function checkResult() {
        isKicking = false;
        // If ball is within goalie's horizontal range
        if (ballTarget.x > goalieX - 50 && ballTarget.x < goalieX + 50) {
            blocks++;
            showMsg("BLOCKED!", "#ef4444");
        } else if (ballTarget.x > 200 && ballTarget.x < 600) {
            score++;
            showMsg("GOAL!", "#4ade80");
        } else {
            blocks++;
            showMsg("MISSED!", "#f97316");
        }

        document.getElementById('soc-score').innerText = score;
        document.getElementById('soc-blocks').innerText = blocks;
        ballPos = { x: 400, y: 500 };

        if (blocks >= 3) {
            setTimeout(() => {
                alert("Game Over! Final Score: " + score);
                exitToMenu();
            }, 1000);
        }
    }

    function showMsg(txt, clr) {
        msg.innerText = txt;
        msg.style.color = clr;
        msg.style.display = "block";
        setTimeout(() => msg.style.display = "none", 1000);
    }

    canvas.onclick = shoot;
    window.onkeydown = (e) => { if(e.code === "Space") shoot(); };

    draw();
}
function startFarm() {
    let f = gameData.farm;
    const CROP_TIME = 8000; // 8 seconds to grow

    stage.innerHTML = `
        <div class="game-ui" style="background: #2d5a27; background-image: radial-gradient(#3a7233 1px, transparent 1px); background-size: 20px 20px;">
            <div style="background: rgba(0,0,0,0.6); padding: 10px 20px; border-radius: 20px; margin-bottom: 20px;">
                <h2 style="color:#fbbf24; margin:0;">💰 <span id="f-coins">0</span></h2>
            </div>
            <div id="farm-grid" style="display:grid; grid-template-columns: repeat(3, 110px); gap:2px; background:#3e2723; border:4px solid #3e2723;"></div>
            <div style="margin-top:20px;">
                <button class="upgrade-btn" id="f-up" style="background:#fbbf24; color:#000;"></button>
            </div>
            <p style="color:#a3e635; font-weight:bold; margin-top:10px;">Cost to Plant: 5 Coins</p>
        </div>`;

    const grid = document.getElementById('farm-grid');
    
    const updateF = () => {
        document.getElementById('f-coins').innerText = f.coins;
        document.getElementById('f-up').innerText = `Upgrade Seeds (Lvl ${f.seedLevel}) - $${f.seedLevel * 100}`;
        grid.innerHTML = '';
        
        f.plots.forEach((p, i) => {
            const div = document.createElement('div');
            div.style = `width:110px; height:110px; position:relative; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:2.5rem; outline: 1px solid rgba(0,0,0,0.2);`;
            
            // Visual States
            if(p.state === 'empty') {
                div.style.background = '#3e2723'; // Dark dry dirt
